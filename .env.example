VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ===== WAHA (WhatsApp notifikasi — PROTOTIPE) =====
# Enable notifikasi WA ke petani saat akses tak-terotorisasi terdeteksi.
# false di production/MVP-demo-offline; true saat mau demo WA sungguhan.
VITE_WAHA_ENABLED=false
# Base URL WAHA (docker compose di mesin lokal).
VITE_WAHA_BASE_URL=http://localhost:3000
# Nama session WAHA (harus cocok dengan WAHA_SESSION di docker-compose.yml).
VITE_WAHA_SESSION=default
# API key WAHA (harus cocok dengan WAHA_API_KEY di docker-compose.yml).
VITE_WAHA_API_KEY=paspor-petani-demo
