# WAHA (WhatsApp HTTP API) — salin ke .env lalu isi nilainya.
# CATATAN: EXPO_PUBLIC_* ikut ter-bundle ke dalam aplikasi dan bisa dibaca
# pengguna. Aman untuk WAHA lokal di LAN; jangan dipakai untuk kunci produksi.

# Harus IP LAN Mac, bukan localhost — HP tidak bisa menjangkau localhost Mac.
EXPO_PUBLIC_WAHA_URL=http://192.168.1.10:3000
EXPO_PUBLIC_WAHA_API_KEY=ganti-dengan-api-key
EXPO_PUBLIC_WAHA_SESSION=default

# Nomor petugas penerima notifikasi (format lokal 08xx atau 62xx).
EXPO_PUBLIC_WA_OFFICER=0812xxxxxxxx

# Skema deep-link status Paspor yang ditunjuk bot harga WA.
# Contoh balasan bot: "Cek status dokumenmu: jejakhijau://status"
# (route: src/app/status.tsx, membaca ?telepon= saat dibuka di app).
EXPO_PUBLIC_STATUS_SCHEME=jejakhijau://status

# Supabase — dipakai HANYA oleh mobile/server/wahaWebhookServer.ts (proses Node
# standalone, terpisah dari bundle Expo). App mobile itu sendiri MASIH sepenuhnya
# offline/AsyncStorage, TIDAK pakai Supabase. Server ini butuh kredensial ini untuk:
# (1) nudge "Paspor lengkap" — cek status petani via nomor telepon di tabel Supabase,
#     bukan AsyncStorage yang tak terjangkau dari proses Node berdiri sendiri;
# (2) harga referensi NYATA dari tabel `transaksi` (Sprint 20, web) — kalau kosong atau
#     belum dikonfigurasi, bot fallback ke SAMPLE_PRICE_SOURCES berlabel DATA DEMO.
# Pakai ANON KEY publik (sama seperti web VITE_SUPABASE_ANON_KEY) — JANGAN service_role.
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_ANON_KEY=ganti-dengan-anon-key
